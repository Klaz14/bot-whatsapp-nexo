# Runtime
NODE_ENV=local
BOT_ENV=local
BOT_TIME_ZONE=America/Argentina/Buenos_Aires
BUSINESS_CALENDAR_PATH=business-calendar.json
BLOCKED_SENDERS_PATH=blocked-senders.json
# Grupos donde la blacklist NO se aplica (los senders bloqueados
# pueden enviar comprobantes en estos grupos como si no estuvieran
# en la blacklist). Array JSON. Si no se define o es vacío,
# la blacklist aplica en TODOS los grupos. Ejemplo:
# BLACKLIST_EXEMPT_GROUPS_JSON=["TT/CAJA NEXO"]
BLACKLIST_EXEMPT_GROUPS_JSON=
BOT_LOG_LEVEL=info
BOT_PROCESSING_ENABLED=true
BOT_DRY_RUN=false
# Acuse de recibo: el bot reacciona al comprobante (👍 = subido, 🕒 = encolado fuera de horario).
REACT_ON_PROCESSED=true

# Google Drive OAuth
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_PENDING_FOLDER_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
GOOGLE_OAUTH_REDIRECT_HOST=127.0.0.1
GOOGLE_OAUTH_REDIRECT_PORT=53682
GOOGLE_OAUTH_TIMEOUT_SECONDS=300
GOOGLE_OAUTH_SCOPE=https://www.googleapis.com/auth/drive.file

# WhatsApp Web session and group routing
WHATSAPP_AUTH_DATA_PATH=.wwebjs_auth
WHATSAPP_CLIENT_ID=
WHATSAPP_GROUPS_CONFIG_PATH=config.json
WHATSAPP_READY_TIMEOUT_SECONDS=120
WHATSAPP_WEB_VERSION=
# Tipo de cache de version de WhatsApp Web: none | local | remote
WHATSAPP_WEB_VERSION_CACHE_TYPE=none
WHATSAPP_WEB_CACHE_PATH=.wwebjs_cache
# Solo para WHATSAPP_WEB_VERSION_CACHE_TYPE=remote. Debe incluir el placeholder {version}.
# Ejemplo (repo wppconnect-team/wa-version):
# WHATSAPP_WEB_VERSION_REMOTE_PATH=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/{version}.html
WHATSAPP_WEB_VERSION_REMOTE_PATH=
# Alternative to WHATSAPP_GROUPS_CONFIG_PATH. Must be a JSON object: {"Group Name":"TAG"}
WHATSAPP_ALLOWED_GROUPS_JSON=

# Optional Puppeteer/Chrome configuration
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=
# Comma-separated list or JSON array.
PUPPETEER_BROWSER_ARGS=

# Local logs
LOG_UPLOADS_PATH=uploads.log
LOG_ERRORS_PATH=errors.log
ALERTS_LOG_PATH=alerts.log
LOG_FORMAT=text
LOG_MASK_PHONE_NUMBERS=true
LOG_STORE_DRIVE_LINKS=false
LOG_MAX_FIELD_LENGTH=120

# Local idempotency store
PROCESSED_STORE_PATH=processed-messages.json
PROCESSED_STORE_TTL_HOURS=720
PROCESSED_STORE_MAX_ITEMS=5000
PENDING_PROCESSOR_INTERVAL_MINUTES=5
PENDING_PROCESSOR_MAX_ATTEMPTS=3
# Tamaño del lote de páginas para conversión de PDFs multi-comprobante. Default 30.
PDF_BATCH_SIZE=30
# F0.3 — Backpressure / concurrencia
# Máximo de handlers de mensaje en paralelo (cola con backpressure). Default 3.
HANDLER_CONCURRENCY=3
# Máximo de conversiones PDF→JPG (pdftocairo) simultáneas; evita picos de RAM/OOM. Default 2.
PDF_CONCURRENCY=2

# F0.4 — Auto-recuperación (anti-zombie). REQUIERE sesión persistida en /data.
# Si se cae la sesión, salir (exit 1) para que la plataforma reinicie y reconecte.
AUTO_RECOVERY_ENABLED=true
WATCHDOG_INTERVAL_SECONDS=60
WATCHDOG_MAX_FAILURES=2
# Puerto del servidor /health. Railway inyecta PORT automáticamente; HEALTH_PORT es override local.
HEALTH_PORT=3000

# F0.5 — Catch-up del backlog ocurrido durante el outage (al arrancar).
CATCHUP_ENABLED=true
CATCHUP_DELAY_SECONDS=30
CATCHUP_WINDOW_MINUTES=30
CATCHUP_FETCH_LIMIT=50
# B1/I1 — Recuperación de caídas LARGAS (override manual, uso eventual).
# Poné la fecha-hora LOCAL de la caída ("YYYY-MM-DD HH:mm"); al reiniciar, el bot recupera
# desde esa hora (en vez de CATCHUP_WINDOW_MINUTES) con un límite de mensajes más alto.
# Después de recuperar, BORRÁ la variable para volver al modo automático. Vacío = automático.
CATCHUP_SINCE=
CATCHUP_MANUAL_FETCH_LIMIT=500

# I2/R6 — Aviso post-caída. Latido persistido: al revivir, si estuvo caído más que el umbral,
# avisa a los grupos de estado "estuve caído ~X min". (El bot caído no puede avisar por WhatsApp;
# el aviso llega recién cuando vuelve.) En Railway: HEARTBEAT_PATH=/data/heartbeat.json
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SECONDS=60
HEARTBEAT_DOWNTIME_THRESHOLD_MINUTES=5
HEARTBEAT_PATH=heartbeat.json

# MOD-01 — Grupos/TAGs dinámicos desde Google Sheets (Service Account).
# Si GOOGLE_SHEETS_ID NO está definida, el bot usa config.json como hoy (legacy).
# Si está definida, Sheets es la ÚNICA fuente de verdad de grupos/TAGs (se ignora config.json).
# Planilla en uso (col K = nombre del grupo de WhatsApp, col E = TAG, desde la fila 2):
GOOGLE_SHEETS_ID=1UybD45jEcUfALjnm8uRJrDoy4U0GSeLeTFi9-hYB9r8
GOOGLE_SHEETS_SHEET_NAME=Hoja 1
GOOGLE_SHEETS_GROUP_COLUMN=K
GOOGLE_SHEETS_TAG_COLUMN=E
# Credenciales del Service Account (una de las dos):
# (a) Ruta al archivo JSON (compartir la planilla como Viewer con su email).
GOOGLE_SHEETS_CREDENTIALS_PATH=
# (b) RECOMENDADA en Railway: pegar el CONTENIDO del JSON en una sola línea. Se guarda cifrado,
#     sin subir archivos al volumen. Si está seteada, tiene prioridad sobre la ruta.
#     NUNCA commitear el valor real (el .gitignore ya protege .env / *service-account*.json).
GOOGLE_SHEETS_CREDENTIALS_JSON=
SHEETS_MATCH_CASE_SENSITIVE=false
# Normalización de TAGs: asis | upper | underscore | upper_underscore (default, recomendado).
SHEETS_TAG_NORMALIZE=upper_underscore
# Cache en disco del mapa grupo->TAG (en Railway: /data/sheets-groups-cache.json).
SHEETS_GROUPS_CACHE_PATH=sheets-groups-cache.json
# Auto-recarga: cada N min relee la planilla y reconoce grupos nuevos SIN deploy ni
# /recargar manual (basta agregar el bot al grupo de la col K). 0 = desactivar.
SHEETS_RELOAD_MINUTES=15

# MOD-04 — Comandos en grupo de control (/resumen /status /forzar /recargar ...).
# Crear el grupo y agregar el bot ANTES de setear esta var (si no, puede bloquear ready).
WHATSAPP_CONTROL_GROUP_NAME=
# Store de métricas diarias (en Railway: /data/daily-stats.json).
STATS_STORE_PATH=daily-stats.json

# MOD-02 — Blacklist + grupos exentos desde una planilla NUEVA del bot (separada de
# cotizaciones). Si no se define, se usa blocked-senders.json + BLACKLIST_EXEMPT_GROUPS_JSON.
# Usa el MISMO Service Account (compartir la planilla nueva como Viewer con su email).
GOOGLE_SHEETS_BOT_CONFIG_ID=
GOOGLE_SHEETS_BLACKLIST_SHEET_NAME=BOT_BLACKLIST
GOOGLE_SHEETS_EXEMPT_SHEET_NAME=BOT_EXEMPT
SHEETS_BLACKLIST_CACHE_PATH=sheets-blacklist-cache.json

# MOD-03 — Difusión masiva (/broadcast). Requiere WHATSAPP_CONTROL_GROUP_NAME.
BROADCAST_CONFIRM_TIMEOUT_MS=300000
BROADCAST_SEND_DELAY_MS=1500

# MOD-05 — Informe semanal de errores vía Claude API (los viernes). Usa fetch nativo (sin SDK).
# Sin ANTHROPIC_API_KEY, igual manda el resumen crudo (sin análisis de IA).
WEEKLY_REPORT_ENABLED=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
WEEKLY_REPORT_HOUR=18
WEEKLY_REPORT_LOOKBACK_DAYS=7
WEEKLY_REPORT_STATE_PATH=weekly-report-state.json

# Operational notifications
WHATSAPP_ALERT_GROUP_NAME=
WHATSAPP_ALERT_GROUPS_JSON=["BOT TEST"]
# Grupos que reciben mensajes operativos (ready, off-hours, on-hours, shutdown).
# Si no se define, hereda de WHATSAPP_ALERT_GROUPS_JSON.
WHATSAPP_STATUS_GROUPS_JSON=["BOT TEST","PRUEBA TEST"]
# Grupos que reciben notificaciones de inicio y fin de día hábil (onHoursStarted y offHoursStarted).
# Si no se define o es vacío, hereda de WHATSAPP_STATUS_GROUPS_JSON (backward-compatible).
WHATSAPP_DAILY_GROUPS_JSON=[]
# Delay entre envíos secuenciales a múltiples grupos para el canal daily (ms). Default 1500.
# 0 = sin delay. Si el valor es negativo o no numérico, se usa 1500.
OPERATIONAL_DAILY_NOTIFY_DELAY_MS=1500
OPERATIONAL_NOTIFICATIONS_ENABLED=true
OPERATIONAL_NOTIFY_ON_READY=true
OPERATIONAL_NOTIFY_ON_OFF_HOURS=true
OPERATIONAL_NOTIFY_ON_SHUTDOWN=false
OPERATIONAL_STATUS_CHECK_INTERVAL_SECONDS=60
# Re-alertar una condición recurrente recién después de N minutos (no silenciarla de por vida).
ALERT_DEDUPE_TTL_MINUTES=30
# Canal de alerta out-of-band (Telegram) para ERROR/CRITICAL: llega aunque el WhatsApp del bot esté caído.
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Safety flags for future phases. Defaults preserve current behavior.
ALLOW_REAL_WHATSAPP_CONNECTION=true
ALLOW_REAL_DRIVE_UPLOADS=true

# Railway /data deployment example.
# Keep secrets and gitignored operational files in the Railway Volume mounted at /data.
# Uncomment/adapt these values in Railway variables instead of committing real secrets.
# BOT_ENV=railway
# GOOGLE_CREDENTIALS_PATH=/data/credentials.json
# GOOGLE_TOKEN_PATH=/data/token.json
# WHATSAPP_AUTH_DATA_PATH=/data/.wwebjs_auth
# WHATSAPP_WEB_CACHE_PATH=/data/.wwebjs_cache
# WHATSAPP_GROUPS_CONFIG_PATH=/data/config.json
# BUSINESS_CALENDAR_PATH=/data/business-calendar.json
# BLOCKED_SENDERS_PATH=/data/blocked-senders.json
# PROCESSED_STORE_PATH=/data/processed-messages.json
# LOG_UPLOADS_PATH=/data/logs/uploads.log
# LOG_ERRORS_PATH=/data/logs/errors.log
# ALERTS_LOG_PATH=/data/logs/alerts.log
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_HEADLESS=true
# PUPPETEER_BROWSER_ARGS=[]
