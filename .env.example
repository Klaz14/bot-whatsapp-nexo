# Runtime
NODE_ENV=local
BOT_ENV=local
BOT_TIME_ZONE=America/Argentina/Buenos_Aires
BUSINESS_CALENDAR_PATH=business-calendar.json
BLOCKED_SENDERS_PATH=blocked-senders.json
# Grupos donde la blacklist NO se aplica (los senders bloqueados
# pueden enviar comprobantes en estos grupos como si no estuvieran
# en la blacklist). Array JSON. Si no se define o es vacío,
# la blacklist aplica en TODOS los grupos. Ejemplo:
# BLACKLIST_EXEMPT_GROUPS_JSON=["TT/CAJA NEXO"]
BLACKLIST_EXEMPT_GROUPS_JSON=
BOT_LOG_LEVEL=info
BOT_PROCESSING_ENABLED=true
BOT_DRY_RUN=false

# Google Drive OAuth
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_PENDING_FOLDER_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
GOOGLE_OAUTH_REDIRECT_HOST=127.0.0.1
GOOGLE_OAUTH_REDIRECT_PORT=53682
GOOGLE_OAUTH_TIMEOUT_SECONDS=300
GOOGLE_OAUTH_SCOPE=https://www.googleapis.com/auth/drive.file

# WhatsApp Web session and group routing
WHATSAPP_AUTH_DATA_PATH=.wwebjs_auth
WHATSAPP_CLIENT_ID=
WHATSAPP_GROUPS_CONFIG_PATH=config.json
WHATSAPP_READY_TIMEOUT_SECONDS=120
WHATSAPP_WEB_VERSION=
# Tipo de cache de version de WhatsApp Web: none | local | remote
WHATSAPP_WEB_VERSION_CACHE_TYPE=none
WHATSAPP_WEB_CACHE_PATH=.wwebjs_cache
# Solo para WHATSAPP_WEB_VERSION_CACHE_TYPE=remote. Debe incluir el placeholder {version}.
# Ejemplo (repo wppconnect-team/wa-version):
# WHATSAPP_WEB_VERSION_REMOTE_PATH=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/{version}.html
WHATSAPP_WEB_VERSION_REMOTE_PATH=
# Alternative to WHATSAPP_GROUPS_CONFIG_PATH. Must be a JSON object: {"Group Name":"TAG"}
WHATSAPP_ALLOWED_GROUPS_JSON=

# Optional Puppeteer/Chrome configuration
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=
# Comma-separated list or JSON array.
PUPPETEER_BROWSER_ARGS=

# Local logs
LOG_UPLOADS_PATH=uploads.log
LOG_ERRORS_PATH=errors.log
ALERTS_LOG_PATH=alerts.log
LOG_FORMAT=text
LOG_MASK_PHONE_NUMBERS=true
LOG_STORE_DRIVE_LINKS=false
LOG_MAX_FIELD_LENGTH=120

# Local idempotency store
PROCESSED_STORE_PATH=processed-messages.json
PROCESSED_STORE_TTL_HOURS=720
PROCESSED_STORE_MAX_ITEMS=5000
PENDING_PROCESSOR_INTERVAL_MINUTES=5
PENDING_PROCESSOR_MAX_ATTEMPTS=3

# Operational notifications
WHATSAPP_ALERT_GROUP_NAME=
WHATSAPP_ALERT_GROUPS_JSON=["BOT TEST"]
# Grupos que reciben mensajes operativos (ready, off-hours, on-hours, shutdown).
# Si no se define, hereda de WHATSAPP_ALERT_GROUPS_JSON.
WHATSAPP_STATUS_GROUPS_JSON=["BOT TEST","PRUEBA TEST"]
OPERATIONAL_NOTIFICATIONS_ENABLED=true
OPERATIONAL_NOTIFY_ON_READY=true
OPERATIONAL_NOTIFY_ON_OFF_HOURS=true
OPERATIONAL_NOTIFY_ON_SHUTDOWN=false
OPERATIONAL_STATUS_CHECK_INTERVAL_SECONDS=60

# Safety flags for future phases. Defaults preserve current behavior.
ALLOW_REAL_WHATSAPP_CONNECTION=true
ALLOW_REAL_DRIVE_UPLOADS=true

# Railway /data deployment example.
# Keep secrets and gitignored operational files in the Railway Volume mounted at /data.
# Uncomment/adapt these values in Railway variables instead of committing real secrets.
# BOT_ENV=railway
# GOOGLE_CREDENTIALS_PATH=/data/credentials.json
# GOOGLE_TOKEN_PATH=/data/token.json
# WHATSAPP_AUTH_DATA_PATH=/data/.wwebjs_auth
# WHATSAPP_WEB_CACHE_PATH=/data/.wwebjs_cache
# WHATSAPP_GROUPS_CONFIG_PATH=/data/config.json
# BUSINESS_CALENDAR_PATH=/data/business-calendar.json
# BLOCKED_SENDERS_PATH=/data/blocked-senders.json
# PROCESSED_STORE_PATH=/data/processed-messages.json
# LOG_UPLOADS_PATH=/data/logs/uploads.log
# LOG_ERRORS_PATH=/data/logs/errors.log
# ALERTS_LOG_PATH=/data/logs/alerts.log
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_HEADLESS=true
# PUPPETEER_BROWSER_ARGS=[]
